#!/usr/bin/env bash
set -u

# Codex notify hook that sends a terminal notification immediately, then gently
# repeats on a tapering schedule. Designed for cmux, with best-effort terminal
# notification fallbacks for other terminal emulators.

readonly DEFAULT_DELAYS="120 180 300 600 1200"
readonly DEFAULT_PROTOCOLS="osc777 osc9"
readonly DEFAULT_SOUND_FILE="/System/Library/Sounds/Ping.aiff"

SHORT_HOST="$(hostname -s 2>/dev/null || hostname 2>/dev/null || printf 'unknown-host')"
TITLE="${REMINDER_TITLE:-Codex @ $SHORT_HOST}"
MESSAGE="${REMINDER_MESSAGE:-Turn ended}"
DELAYS="${REMINDER_DELAYS:-$DEFAULT_DELAYS}"
STATE_DIR="${REMINDER_STATE_DIR:-${XDG_STATE_HOME:-$HOME/.local/state}/poke-mon}"
STATE_KEY="${REMINDER_STATE_KEY:-}"
SOUND_FILE="${REMINDER_SOUND_FILE:-$DEFAULT_SOUND_FILE}"
SOUND_FILES="${REMINDER_SOUND_FILES:-}"
SOUND_COMMAND="${REMINDER_SOUND_COMMAND:-}"
PLAY_LOCAL_SOUND="${REMINDER_PLAY_LOCAL_SOUND:-auto}"
ALLOW_STDOUT_FALLBACK="${REMINDER_STDOUT_FALLBACK:-1}"
REMINDER_ONCE="${REMINDER_ONCE:-0}"
PROTOCOLS="${REMINDER_PROTOCOLS:-$DEFAULT_PROTOCOLS}"
CMUX_NOTIFY="${REMINDER_CMUX_NOTIFY:-1}"
PID_FILE=""
TOKEN_FILE=""
LOG_FILE=""

usage() {
  cat <<'EOF'
Usage: poke-mon [--cancel | --test-sounds [COUNT] | --worker TOKEN | --help]

Codex notify hook for terminal-based turn-ended reminders.

Environment:
  REMINDER_TITLE             Notification title. Default: "Codex @ <host>"
  REMINDER_MESSAGE           Notification body. Default: "Turn ended"
  REMINDER_DELAYS            Reminder delays in seconds. Default: "120 180 300 600 1200"
  REMINDER_ONCE              Set to 1 to notify once without starting reminders.
  REMINDER_STATE_DIR         State directory. Default: $XDG_STATE_HOME or ~/.local/state
  REMINDER_STATE_KEY         Optional key for isolating concurrent sessions.
  REMINDER_PLAY_LOCAL_SOUND  auto, 0, false, no, or off. Default: auto
  REMINDER_SOUND_FILE        macOS sound file used by afplay.
  REMINDER_SOUND_FILES       Space-separated sound sequence for immediate + reminders.
  REMINDER_SOUND_COMMAND     Optional command. Receives sound file as $1 and step as $2.
  REMINDER_STDOUT_FALLBACK   Set to 0 for command hooks where stdout has protocol meaning.
  REMINDER_PROTOCOLS         Space-separated: osc777 osc9 bell. Default: "osc777 osc9"
  REMINDER_CMUX_NOTIFY       Set to 0 to skip direct `cmux notify`.
EOF
}

sanitize_state_key() {
  printf '%s' "$1" | LC_ALL=C tr -c 'A-Za-z0-9._=-' '_'
}

init_state_dir() {
  if [ -n "$STATE_KEY" ]; then
    safe_state_key="$(sanitize_state_key "$STATE_KEY")"
    STATE_DIR="$STATE_DIR/$safe_state_key"
  fi

  if mkdir -p "$STATE_DIR" 2>/dev/null; then
    :
  else
    STATE_DIR="${TMPDIR:-/tmp}/poke-mon-${UID:-user}"
    mkdir -p "$STATE_DIR" 2>/dev/null || exit 1
  fi

  PID_FILE="$STATE_DIR/reminder.pid"
  TOKEN_FILE="$STATE_DIR/token"
  LOG_FILE="$STATE_DIR/reminder.log"
}

sanitize_osc_field() {
  value="$1"
  value="${value//$'\033'/}"
  value="${value//$'\007'/}"
  value="${value//$'\r'/ }"
  value="${value//$'\n'/ }"
  value="${value//;/ -}"
  printf '%s' "$value"
}

notification_sequence() {
  protocol="$1"
  title="$2"
  message="$3"

  case "$protocol" in
    osc777)
      # cmux-compatible desktop notification escape sequence.
      printf '\033]777;notify;%s;%s\007' "$title" "$message"
      ;;
    osc9)
      # Best-effort terminal notification sequence supported by some terminals.
      printf '\033]9;%s: %s\007' "$title" "$message"
      ;;
    bell|bel)
      printf '\007'
      ;;
    *)
      return 1
      ;;
  esac
}

write_notification_to_tty() {
  target_tty="$1"
  title="$(sanitize_osc_field "$TITLE")"
  message="$(sanitize_osc_field "$MESSAGE")"
  wrote=0

  [ -n "$target_tty" ] || return 1
  [ -w "$target_tty" ] || return 1

  for protocol in $PROTOCOLS; do
    notification_sequence "$protocol" "$title" "$message" > "$target_tty" 2>/dev/null && wrote=1
  done

  [ "$wrote" -eq 1 ]
}

write_notification_to_stdout() {
  title="$(sanitize_osc_field "$TITLE")"
  message="$(sanitize_osc_field "$MESSAGE")"

  for protocol in $PROTOCOLS; do
    notification_sequence "$protocol" "$title" "$message"
  done
}

sound_for_step() {
  step="${1:-0}"
  index=0
  selected="$SOUND_FILE"

  if [ -n "$SOUND_FILES" ]; then
    for candidate in $SOUND_FILES; do
      selected="$candidate"
      [ "$index" -ge "$step" ] && break
      index=$((index + 1))
    done
  fi

  printf '%s' "$selected"
}

sound_step_count() {
  count=0

  if [ -n "$SOUND_FILES" ]; then
    for _candidate in $SOUND_FILES; do
      count=$((count + 1))
    done
  fi

  [ "$count" -gt 0 ] || count=1
  printf '%s' "$count"
}

play_sound() {
  step="${1:-0}"
  mode="${2:-async}"

  case "$PLAY_LOCAL_SOUND" in
    0|false|FALSE|no|NO|off|OFF)
      return 0
      ;;
  esac

  step_sound="$(sound_for_step "$step")"

  if [ -n "$SOUND_COMMAND" ]; then
    if [ "$mode" = "sync" ]; then
      sh -c "$SOUND_COMMAND" poke-mon-sound "$step_sound" "$step"
    else
      sh -c "$SOUND_COMMAND" poke-mon-sound "$step_sound" "$step" >/dev/null 2>&1 &
    fi
    return 0
  fi

  if [ -z "${SSH_TTY:-}" ] && command -v afplay >/dev/null 2>&1 && [ -r "$step_sound" ]; then
    if [ "$mode" = "sync" ]; then
      afplay "$step_sound"
    else
      afplay "$step_sound" >/dev/null 2>&1 &
    fi
  fi
}

test_sounds() {
  count="${1:-$(sound_step_count)}"

  case "$count" in
    ''|*[!0-9]*)
      count="$(sound_step_count)"
      ;;
  esac

  step=0
  while [ "$step" -lt "$count" ]; do
    play_sound "$step" sync
    step=$((step + 1))
    [ "$step" -lt "$count" ] && sleep 1
  done
}

notify() {
  step="${1:-0}"
  notified=0

  if [ "$CMUX_NOTIFY" != "0" ] && command -v cmux >/dev/null 2>&1; then
    cmux notify --title "$TITLE" --body "$MESSAGE" >/dev/null 2>&1 && notified=1
  fi

  if [ -n "${SSH_TTY:-}" ]; then
    write_notification_to_tty "$SSH_TTY" && notified=1
  fi

  if command -v tmux >/dev/null 2>&1; then
    while IFS= read -r client_tty; do
      [ -n "$client_tty" ] || continue
      write_notification_to_tty "$client_tty" && notified=1
    done <<EOF
$(tmux list-clients -F '#{client_tty}' 2>/dev/null || true)
EOF
    tmux display-message "$TITLE: $MESSAGE" 2>/dev/null || true
  fi

  if [ "$notified" -eq 0 ] && [ -w /dev/tty ]; then
    write_notification_to_tty /dev/tty && notified=1
  fi

  if [ "$notified" -eq 0 ] && [ "$ALLOW_STDOUT_FALLBACK" != "0" ]; then
    write_notification_to_stdout
  fi

  play_sound "$step" async
}

cancel_existing() {
  if [ -f "$PID_FILE" ]; then
    old_pid="$(cat "$PID_FILE" 2>/dev/null || true)"
    if [ -n "${old_pid:-}" ] && kill -0 "$old_pid" 2>/dev/null; then
      kill "$old_pid" 2>/dev/null || true
    fi
  fi
}

run_worker() {
  token="${1:-}"
  [ -n "$token" ] || exit 1
  step=1

  for delay in $DELAYS; do
    case "$delay" in
      ''|*[!0-9]*)
        continue
        ;;
    esac

    sleep "$delay"
    [ "$(cat "$TOKEN_FILE" 2>/dev/null || true)" = "$token" ] || exit 0
    notify "$step"
    step=$((step + 1))
  done
}

start_worker() {
  token="$1"

  if command -v setsid >/dev/null 2>&1; then
    setsid "$0" --worker "$token" >>"$LOG_FILE" 2>&1 &
  else
    nohup "$0" --worker "$token" >>"$LOG_FILE" 2>&1 &
  fi

  printf '%s\n' "$!" > "$PID_FILE"
}

main() {
  case "${1:-}" in
    --help|-h)
      usage
      exit 0
      ;;
    --cancel)
      init_state_dir
      cancel_existing
      : > "$TOKEN_FILE"
      exit 0
      ;;
    --test-sounds)
      test_sounds "${2:-}"
      exit 0
      ;;
    --worker)
      init_state_dir
      run_worker "${2:-}"
      exit 0
      ;;
  esac

  case "$REMINDER_ONCE" in
    1|true|TRUE|yes|YES|on|ON)
      notify 0
      exit 0
      ;;
  esac

  init_state_dir
  cancel_existing
  token="$(date +%s)-$$"
  printf '%s\n' "$token" > "$TOKEN_FILE"

  notify 0
  start_worker "$token"
}

main "$@"
